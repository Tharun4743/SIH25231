{
  "name": "aura-desktop",
  "version": "1.0.0",
  "description": "Aura – AI Unified Retrieval Assistant",
  "author": "TharunkumarK",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "node scripts/build.js",
    "package": "npx electron-builder build --win --publish never"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.aura.airetrieval.desktop",
    "productName": "Aura",
    "copyright": "Copyright © 2025 Aura AI",
    "compression": "normal",
    "removePackageScripts": true,
    "nodeGypRebuild": false,
    "buildDependenciesFromSource": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "loading.html",
      "package.json",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "jre",
        "to": "jre",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "backend",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "frontend/dist",
        "to": "frontend/dist",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": ".venv",
        "to": ".venv",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "data",
        "to": "data",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "appx",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "appx": {
      "applicationId": "AuraAIUnifiedRetrievalAssistant",
      "backgroundColor": "#0F172A",
      "displayName": "Aura",
      "identityName": "TharunkumarK.AuraAIUnifiedRetrievalAssistant-Tharu",
      "publisher": "CN=45B777BE-50D5-4401-8119-B115CE517C3D",
      "publisherDisplayName": "TharunkumarK",
      "languages": [
        "en-US"
      ],
      "minVersion": "10.0.19041.0"
    }
  }
}
